{
  "name": "@luxqw/torio",
  "version": "1.5.5",
  "description": "A sleek, zero-setup torrent finder and downloader that lives right in your terminal.",
  "type": "module",
  "bin": {
    "torio": "dist/cli.cjs"
  },
  "files": [
    "dist",
    "vendor/ip-set"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx src/index.tsx",
    "build": "tsup",
    "postbuild": "node scripts/postbuild.cjs",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "verify:seeding": "tsx scripts/verify-seeding.ts",
    "previews": "tsx scripts/render-previews.tsx",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "torrent",
    "torrent-client",
    "torrent-search",
    "downloader",
    "magnet",
    "magnet-links",
    "p2p",
    "webtorrent",
    "seeding",
    "tui",
    "terminal",
    "cli",
    "ink",
    "zero-configuration",
    "zero-setup",
    "fitgirl"
  ],
  "author": "luxqw",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luxqw/torio.git"
  },
  "homepage": "https://github.com/luxqw/torio#readme",
  "bugs": {
    "url": "https://github.com/luxqw/torio/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "env-paths": "^4.0.0",
    "ink": "^7.0.5",
    "ip-set": "file:vendor/ip-set",
    "parse-torrent": "^11.0.21",
    "react": "^19.2.7",
    "webtorrent": "^2.4.1"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "ink-testing-library": "^4.0.0",
    "semantic-release": "^25.0.7",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
